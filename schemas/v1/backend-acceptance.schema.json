{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crytex.local/schemas/v1/backend-acceptance.schema.json",
  "title": "Crytex Backend Acceptance Report",
  "type": "object",
  "required": ["passed", "stages"],
  "properties": {
    "passed": { "type": "boolean" },
    "mode": { "type": "string" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "evidence": {}
        },
        "additionalProperties": true
      }
    },
    "diagnostics_path": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
