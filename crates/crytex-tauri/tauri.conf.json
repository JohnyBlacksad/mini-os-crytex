{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crytex",
  "version": "0.1.0",
  "identifier": "local.crytex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Crytex",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  }
}
